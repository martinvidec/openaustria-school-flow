#
# SchoolFlow production Docker Compose .env.example (DEPLOY-03).
#
# Copy to `docker/.env` and fill in real secrets before running:
#
#   cp docker/.env.example docker/.env
#   $EDITOR docker/.env
#   docker compose -f docker/docker-compose.yml -f docker/docker-compose.prod.yml up -d
#
# NEVER commit docker/.env to git. It is already covered by .gitignore
# (or should be -- see deferred-items.md if not).
#

# ==============================================================================
# PostgreSQL (primary application database)
# ==============================================================================
POSTGRES_PASSWORD=change_me_please_use_a_long_random_string

# ==============================================================================
# Keycloak (identity provider)
# ==============================================================================
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_please_use_a_long_random_string
KEYCLOAK_DB_PASSWORD=change_me_please_use_a_different_long_random_string

# ==============================================================================
# Web Push / VAPID (Phase 09-03)
# ==============================================================================
# Generate with:  npx web-push generate-vapid-keys --json
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@schoolflow.example

# ==============================================================================
# API (optional overrides -- defaults are set in docker-compose.prod.yml)
# ==============================================================================
# DATABASE_URL is composed from POSTGRES_PASSWORD by the compose file.
# REDIS_HOST / KEYCLOAK_URL are set to the internal docker network names.
# Override here only if you need non-default ports or external services.
#
# DATABASE_URL=postgresql://schoolflow:${POSTGRES_PASSWORD}@postgres:5432/schoolflow
# REDIS_HOST=redis
# REDIS_PORT=6379
# KEYCLOAK_URL=http://keycloak:8080
# KEYCLOAK_REALM=schoolflow

# Internal URL the Java solver uses to call back to the NestJS API
# (TIME-04, see .planning/v1.0-MILESTONE-AUDIT.md finding 2).
# The solver POSTs to {API_INTERNAL_URL}/progress/{runId}, so this base
# URL must include BOTH the global prefix 'api/v1' AND the
# SolverCallbackController prefix 'api/internal/solver'. In Docker
# Compose, this is the api service name + port on the internal network.
#
# Leave unset to use the default baked into docker-compose.prod.yml.
# API_INTERNAL_URL=http://api:3000/api/v1/api/internal/solver

# ==============================================================================
# Backup / restore scripts (docker/scripts/backup.sh, restore.sh)
# ==============================================================================
# BACKUP_DIR is where backup.sh writes timestamped dumps + manifest.
# RETAIN_DAYS is how many days of backups to keep before pruning.
# UPLOAD_DIR is the host path containing user-uploaded attachments
#            (classbook excuses, etc.). Leave unset to skip uploads backup.
BACKUP_DIR=/backups
RETAIN_DAYS=7
UPLOAD_DIR=/data/uploads
