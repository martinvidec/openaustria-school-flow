DATABASE_URL=postgresql://schoolflow:schoolflow_dev@localhost:5432/schoolflow
REDIS_URL=redis://localhost:6379
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=schoolflow
KEYCLOAK_CLIENT_ID=schoolflow-api
# Service-account client used by the NestJS Keycloak Admin client (user
# directory, role management, link-person). Matches the
# `schoolflow-admin-api` client + secret declared in
# `docker/keycloak/realm-export.json`. The secret value is dev-only —
# rotate before any non-localhost deployment.
KEYCLOAK_ADMIN_CLIENT_ID=schoolflow-admin-api
KEYCLOAK_ADMIN_CLIENT_SECRET=local-dev-only-secret
NODE_ENV=development
PORT=3000

# Phase 9 Plan 03 — Web Push (MOBILE-02 / D-05)
# Generate with: pnpm --filter @schoolflow/api exec web-push generate-vapid-keys --json
# These are LONG-LIVED — rotating them invalidates every existing browser subscription.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@schoolflow.example
